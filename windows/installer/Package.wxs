<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="Compartir Archivos RED"
           Manufacturer="Jhon Supelano"
           Version="$(var.Version)"
           UpgradeCode="98D30AE5-365D-43A2-A8FD-ADA5F2CA42C4"
           Scope="perMachine"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="Ya hay una versión más reciente de Compartir Archivos RED instalada." />
    <MediaTemplate EmbedCab="yes" />

    <Icon Id="AppIcon" SourceFile="$(var.PublishDir)\CompartirArchivosRED.exe" />
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/USUARIO/CompartirArchivosRED" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="Compartir Archivos RED" />
    </StandardDirectory>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppShortcutFolder" Name="Compartir Archivos RED" />
    </StandardDirectory>

    <!-- Todos los archivos publicados (self-contained) se cosechan en tiempo de build -->
    <ComponentGroup Id="AppFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishDir)\**" />
    </ComponentGroup>

    <!-- Acceso directo en el menú Inicio -->
    <ComponentGroup Id="AppShortcuts">
      <Component Id="StartMenuShortcut" Directory="AppShortcutFolder" Guid="B6A2F1D3-4C7E-4E82-9F55-0A1B2C3D4E5F">
        <Shortcut Id="StartMenuShortcut"
                  Name="Compartir Archivos RED"
                  Target="[INSTALLFOLDER]CompartirArchivosRED.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="RemoveAppShortcutFolder" Directory="AppShortcutFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\CompartirArchivosRED"
                       Name="installed" Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <Feature Id="Main" Title="Compartir Archivos RED" Level="1">
      <ComponentGroupRef Id="AppFiles" />
      <ComponentGroupRef Id="AppShortcuts" />
    </Feature>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
    <WixVariable Id="WixUILicenseRtf" Value="license.rtf" />

  </Package>
</Wix>
